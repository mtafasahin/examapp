{
	# Email is optional but recommended for Let's Encrypt
	# email {$LETSENCRYPT_EMAIL}
}

{$DOMAIN} {
	encode gzip

	# Optional override for TLS policy.
	# Example (temporary): set env CADDY_TLS='tls internal' to serve an internal cert
	# without hitting Let's Encrypt rate limits. Leave empty for normal public ACME.
	{$CADDY_TLS}

	# Keycloak must be reachable on the public domain for OIDC flows.
	# Serve it directly from Caddy (bypassing Ocelot) for common Keycloak paths.
	@keycloak path /realms /realms/* /resources /resources/* /admin /admin/* /js /js/* /robots.txt
	handle @keycloak {
		reverse_proxy keycloak:8080 {
			# Keycloak enforces HTTPS for external requests (realm ssl-required=external).
			# In some setups the connection to Caddy may be HTTP (LB/Cloudflare in front),
			# so forwarding `{scheme}` can incorrectly become `http` and Keycloak returns
			# {"error":"invalid_request","error_description":"HTTPS required"}.
			# Force the external scheme/port to what clients use.
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Port 443
		}
	}

	# Expose MinIO admin console under /minio for production operations.
	# handle_path strips the /minio prefix before proxying to console service.
	handle_path /minio* {
		reverse_proxy exam-minio:9001
	}	

	# Expose n8n editor and webhook endpoints under /n8n.
	handle_path /n8n* {
		reverse_proxy n8n:5678
	}

	# Redirect bare root to Angular welcome page
	handle / {
		redir https://{host}/welcome permanent
	}

	# Single entry-point: forward everything else to Ocelot gateway
	handle {
		reverse_proxy ocelot-gateway:5678
	}
}

# Optional dedicated host for MinIO console.
# Example: if DOMAIN=staging.hedefokul.com, this serves minio.staging.hedefokul.com.
minio.{$DOMAIN} {
	encode gzip
	{$CADDY_TLS}

	reverse_proxy exam-minio:9001
}

# Optional dedicated host for pgAdmin.
# Example: if DOMAIN=staging.hedefokul.com, this serves pgadmin.staging.hedefokul.com.
pgadmin.{$DOMAIN} {
	encode gzip
	{$CADDY_TLS}

	reverse_proxy exam-pgadmin:80
}

# Optional dedicated host for n8n.
# Example: if DOMAIN=staging.hedefokul.com, this serves n8n.staging.hedefokul.com.
n8n.{$DOMAIN} {
	encode gzip
	{$CADDY_TLS}

	reverse_proxy exam-n8n:5678
}

# Optional dedicated host for RabbitMQ Management.
# Example: if DOMAIN=staging.hedefokul.com, this serves rabbitmq.staging.hedefokul.com.
rabbitmq.{$DOMAIN} {
	encode gzip
	{$CADDY_TLS}

	reverse_proxy exam-rabbitmq:15672
}


